@page
@model EmbeddingLabModel
@{
    ViewData["Title"] = "Embedding Lab";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/embeddinglab.css" asp-append-version="true" />
}

<div id="console-alert" class="alert-toast">
    <i id="alert-icon" class="bi bi-exclamation-circle"></i>
    <span id="alert-message">Warning</span>
    <button id="close-alert-btn" class="alert-toast__close">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="lab-container">

    <div class="lab-toolbar">
        <h2 class="lab-toolbar__title">Live Comparison Tool</h2>

        <div style="flex: 1; max-width: 400px; margin-left: 20px;">
            <div id="active-model-display" class="console-select font-mono" style="display: flex; align-items: center; background-color: var(--console-bg-darker); cursor: not-allowed; opacity: 0.8; height: 38px; padding: 0 1rem; border-radius: 4px; border: 1px solid var(--console-border); color: var(--console-text);">
                @(string.IsNullOrEmpty(Model.ActiveModel) ? "No active pipeline target" : Model.ActiveModel)
            </div>
        </div>
    </div>

    <div class="lab-grid">
        <div class="lab-sidebar">
            <textarea id="text1" class="lab-textarea" placeholder="Enter first text..."></textarea>
            <textarea id="text2" class="lab-textarea" placeholder="Enter second text..."></textarea>

            <button id="analyze-btn" class="lab-btn-primary" @(string.IsNullOrEmpty(Model.ActiveModel) ? "disabled" : "")>
                @(string.IsNullOrEmpty(Model.ActiveModel) ? "No models available" : "Analyze & Compare")
            </button>

            <div class="gauge-card">
                <div class="gauge-card__title">Similarity Score</div>
                <div id="gauge-container" class="gauge-bar">
                    <div id="gauge-fill" class="gauge-bar__fill"></div>
                    <div id="similarity-score" class="gauge-bar__text">0%</div>
                </div>
            </div>

            <div class="metadata-card">
                <div class="metadata-grid">
                    <div class="metadata-item" title="Vector Dimensions">
                        <i class="bi bi-rulers"></i>
                        <div class="metadata-text">
                            <span class="metadata-label">Dimensions</span>
                            <span class="metadata-value" id="meta-dimensions">--</span>
                        </div>
                    </div>
                    <div class="metadata-item" title="Tokens used (Text 1 / Text 2)">
                        <i class="bi bi-input-cursor-text"></i>
                        <div class="metadata-text">
                            <span class="metadata-label">Tokens</span>
                            <span class="metadata-value" id="meta-tokens">-- / --</span>
                        </div>
                    </div>
                    <div class="metadata-item" title="Processing time">
                        <i class="bi bi-stopwatch"></i>
                        <div class="metadata-text">
                            <span class="metadata-label">Latency</span>
                            <span class="metadata-value" id="meta-latency">-- ms</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="lab-main-panel">
            <div class="charts-container">

                <!-- Radar Chart -->
                <div class="chart-wrapper">
                    <div class="chart-title">Semantic Distance Radar</div>
                    <div class="radar-screen">
                        <div class="radar-ring radar-ring-1"></div>
                        <div class="radar-ring radar-ring-2"></div>
                        <div class="radar-ring radar-ring-3"></div>
                        <div class="radar-crosshair-x"></div>
                        <div class="radar-crosshair-y"></div>
                        <div class="radar-scanner" id="radar-scanner-sweep"></div>

                        <svg id="radar-canvas" class="radar-canvas" viewBox="0 0 200 200">
                            <line id="radar-laser" x1="100" y1="100" x2="100" y2="100" />

                            <g id="radar-group-a" class="radar-hidden">
                                <circle id="radar-dot-a" cx="100" cy="100" r="4" class="radar-dot dot-a" />
                                <text id="radar-label-a" x="100" y="90" class="radar-label">Text 1</text>
                            </g>

                            <g id="radar-group-b" class="radar-hidden">
                                <circle id="radar-dot-b" cx="100" cy="100" r="4" class="radar-dot dot-b" />
                                <text id="radar-label-b" x="100" y="90" class="radar-label">Text 2</text>
                            </g>
                        </svg>
                    </div>

                    <div class="radar-results-display">
                        <div class="radar-result-item">
                            <div class="radar-result-label">Cosine Similarity</div>
                            <div class="radar-result-value" id="radar-score-display">0.000</div>
                        </div>
                        <div class="radar-result-item">
                            <div class="radar-result-label">Vector Distance</div>
                            <div class="radar-result-value" id="radar-distance-display">0.000</div>
                        </div>
                    </div>
                </div>

                <!-- Linear Chart -->
                <div class="chart-wrapper">
                    <div class="chart-title">Vector Magnitude Analysis</div>
                    <div class="chart-container">
                        <canvas id="vectorChart" class="lab-chart"></canvas>
                    </div>
                </div>


            </div>
        </div>

    </div>

    <footer class="lab-footer-info">
        <div class="lab-footer-info__section">
            <h3 class="lab-footer-info__title">What to explore?</h3>
            <ul class="lab-footer-info__list">
                <li>• <b>Semantic Similarity:</b> Validate how closely related two different phrasings truly are.</li>
                <li>• <b>Model Performance:</b> Compare how different pipelines interpret the same linguistic structures.</li>
                <li>• <b>Anomaly Detection:</b> Identify texts that models interpret in unexpected or outlier ways.</li>
            </ul>
        </div>
        <div class="lab-footer-info__section">
            <h3 class="lab-footer-info__title">How the chart helps</h3>
            <p class="lab-footer-info__text">
                The chart acts as a <b>semantic X-ray</b>. Overlapping lines visualize which high-dimensional features align between texts. Divergent patterns highlight conceptual dissonance, offering deep insights into the reasoning behind the model's similarity score.
            </p>
        </div>
    </footer>
</div>

<div id="embedding-config" data-api-url="@Model.APIUrl" style="display: none;"></div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script src="~/js/pages/embeddinglab.js" asp-append-version="true"></script>
}